{
  "name": "crash-game",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "docker:prune": "docker compose down -v --rmi all --remove-orphans && docker volume prune -f"
  },
  "devDependencies": {
    "@types/supertest": "^7.2.0",
    "bun-types": "latest",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "crash-game": "."
  }
}
